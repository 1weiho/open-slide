{
  "name": "@open-slide/core",
  "version": "0.0.4",
  "description": "Runtime and CLI for open-slide — write slides in slides/, we handle the rest.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.js"
    }
  },
  "bin": {
    "open-slide": "./bin.js"
  },
  "files": [
    "bin.js",
    "dist",
    "src/app",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "slides",
    "presentation",
    "react",
    "vite"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^4.3.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "emoji-picker-react": "^4.18.0",
    "fast-glob": "^3.3.2",
    "fflate": "^0.8.2",
    "lucide-react": "^1.8.0",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "shadcn": "^4.3.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "vite": "^5.4.10"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "tsdown": "^0.9.9",
    "typescript": "^5.9.3"
  }
}
