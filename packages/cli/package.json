{
  "name": "@open-slide/cli",
  "version": "0.0.4",
  "description": "Scaffold an open-slide workspace with Claude Code skills preconfigured.",
  "type": "module",
  "bin": {
    "open-slide": "dist/cli.js"
  },
  "files": [
    "dist",
    "template",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown && node dist/sync-template.js",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "slides",
    "presentation",
    "claude-code",
    "scaffold"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsdown": "^0.9.9",
    "typescript": "^5.9.3"
  }
}
